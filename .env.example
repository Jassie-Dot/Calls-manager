TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX

GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

GOOGLE_CALENDAR_ID=primary
GOOGLE_CREDENTIALS_FILE=credentials.json

# Full public URL of this server (ngrok URL during dev, Render URL in prod)
BASE_URL=https://xxxx.ngrok-free.app

# Business config - change these per client
BUSINESS_NAME=Grand Spice Restaurant
BUSINESS_TYPE=restaurant
OPEN_DAYS=Monday,Tuesday,Wednesday,Thursday,Friday,Saturday,Sunday
OPEN_TIME=12:00
CLOSE_TIME=22:00
SLOT_DURATION_MINUTES=60
TIMEZONE=Asia/Kolkata

# AI and speech config
LLM_MODEL=llama-3.1-8b-instant
MAX_TOKENS=120
SPEECH_TIMEOUT=3
MIN_SPEECH_CONFIDENCE=0.4

# Twilio Gather uses one STT language at a time. Start with hi-IN for India,
# then the app switches future Gather prompts after it detects the caller's language.
DEFAULT_LANGUAGE=hinglish
DEFAULT_RECOGNITION_LANGUAGE=hi-IN
ENGLISH_RECOGNITION_LANGUAGE=en-IN
HINDI_RECOGNITION_LANGUAGE=hi-IN
HINGLISH_RECOGNITION_LANGUAGE=hi-IN
TWILIO_SPEECH_MODEL=phone_call
TWILIO_SPEECH_HINTS=booking,reservation,table,appointment,guests,people,namaste,haan,nahi,kal,aaj,parson,baje,log

# Edge TTS voices. Run `edge-tts --list-voices` if you want different voices.
TTS_VOICE=en-IN-NeerjaNeural
ENGLISH_TTS_VOICE=en-IN-NeerjaNeural
HINDI_TTS_VOICE=hi-IN-SwaraNeural
HINGLISH_TTS_VOICE=hi-IN-SwaraNeural
